# Gradle
.gradle/
.kotlin/
build/
local.properties

# Node — only for commitlint + Changesets tooling (per D18); the SDK itself is Java
node_modules/
npm-debug.log*

# IDE
.idea/
*.iml
.vscode/
.classpath
.project
.settings/

# Coding-agent side channels (Conductor workspace state, etc.)
