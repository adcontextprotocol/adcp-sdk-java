# (regenerated from .agents/roles/ by scripts/import-claude-agents.mjs).
.claude/*
!.claude/agents/
.context/
.local/

# OS
.DS_Store

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# JARs — except the Gradle wrapper.
*.jar
!gradle/wrapper/gradle-wrapper.jar

# JVM crash logs
hs_err_pid*
replay_pid*

# Codex agent config — locally generated by scripts/import-claude-agents.mjs
.codex/
